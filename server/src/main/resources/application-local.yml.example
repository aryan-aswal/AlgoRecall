# Copy this file as application-local.yml and fill in your real values.
# application-local.yml is gitignored and will NOT be committed.
# Activate with: --spring.profiles.active=local

spring:
  datasource:
    username: postgres
    password: your-db-password

  mail:
    username: your-email@gmail.com
    password: your-gmail-app-password
    enabled: true

app:
  jwt:
    secret: your-jwt-secret-hex-key
  firebase:
    enabled: true
